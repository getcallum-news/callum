# Callum Backend — Environment Variables
# Copy this file to .env and fill in the values.

# Supabase PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# Random 32+ character string for signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=

# Comma-separated allowed origins for CORS (e.g., https://callum.app,https://www.callum.app)
ALLOWED_ORIGINS=http://localhost:3000

# Path to Firebase service account JSON file (for push notifications)
FIREBASE_CREDENTIALS_PATH=

# VAPID keys for Web Push (generate with: python -c "from pywebpush import webpush; print(webpush.generate_vapid_keys())")
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Your email for VAPID claims (required by Web Push spec)
VAPID_CLAIMS_EMAIL=

# Sentry DSN for error monitoring (from sentry.io project settings)
SENTRY_DSN=

# Set to "true" in production to enable HTTPS redirect, stricter validation, etc.
IS_PRODUCTION=false
